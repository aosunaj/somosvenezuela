# SomosVenezuela · variables de entorno (PLANTILLA)
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.

# ── App ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# ── Supabase / PostgreSQL ──────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # SECRETO: solo backend
DATABASE_URL=                     # postgresql://...  (para migraciones)

# ── Telegram Bot ───────────────────────────────────
TELEGRAM_BOT_TOKEN=               # de BotFather
TELEGRAM_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (Meta) ──────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=            # para validar el webhook
WHATSAPP_APP_SECRET=             # para verificar firmas

# ── Claude API (IA: matching, NLP, OCR) ────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6     # ajustar al modelo disponible

# ── Cloudinary (fotos) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Satélite (Copernicus EMS) — fase 8 ─────────────
COPERNICUS_API_KEY=

# ── Seguridad / operación ──────────────────────────
RATE_LIMIT_MAX=100               # peticiones por ventana
RATE_LIMIT_WINDOW=1m
LOG_LEVEL=info                   # nunca loguear PII
