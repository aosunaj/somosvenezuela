{
  "name": "core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./menu": {
      "types": "./dist/menu.d.ts",
      "import": "./dist/menu.js"
    },
    "./unified-entry": {
      "types": "./dist/unified-entry.d.ts",
      "import": "./dist/unified-entry.js"
    },
    "./dedup": {
      "types": "./dist/dedup.d.ts",
      "import": "./dist/dedup.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"[lint] core: sin linter configurado en esta fase\" && exit 0"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
